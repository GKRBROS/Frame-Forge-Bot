{
  "version": 2,
  "functions": {
    "api/ssr.ts": {
      "includeFiles": "dist/server/assets/**"
    }
  },
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/dist/client/assets/$1"
    },
    {
      "source": "/favicon.ico",
      "destination": "/dist/client/favicon.ico"
    },
    {
      "source": "/(.*)",
      "destination": "/api/ssr"
    }
  ]
}
